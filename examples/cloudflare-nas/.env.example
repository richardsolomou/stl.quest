# Persistent metadata, sessions, and incomplete uploads
DATA_HOST_DIR=/mnt/HDDs/STL/.printhub-data
# Original STLs and generated previews
PRINTS_HOST_DIR=/mnt/HDDs/STL

# Remotely managed tunnel token from Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# local (default) or trusted-header
AUTH_PROVIDER=local
# Required only while claiming the first local operator; remove after setup.
SETUP_TOKEN=

# Only used in trusted-header mode with Cloudflare Access
AUTH_EMAIL_HEADER=Cf-Access-Authenticated-User-Email
TRUSTED_PROXY_SECRET=
OPERATOR_EMAILS=you@example.com
