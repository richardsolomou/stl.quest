# Host paths for the two container mounts. Everything else — storage,
# board visibility, telemetry — is configured in the app under Settings.
DATA_HOST_DIR=./printhub-data
PRINTS_HOST_DIR=./prints
# Set to true when one deployment serves independent customer workspaces.
# PRINTHUB_HOSTED=true
# Set these to the external HTTPS origin when running behind a reverse proxy.
# BETTER_AUTH_URL=https://printhub.example.com
# BETTER_AUTH_TRUSTED_ORIGINS=https://printhub.example.com
