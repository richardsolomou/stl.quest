# Host paths for the two container mounts. Everything else — storage,
# board visibility, telemetry — is configured in the app under Settings.
DATA_HOST_DIR=./printhub-data
PRINTS_HOST_DIR=./prints
PUID=1000
PGID=1000
# Set to true when one deployment serves independent customer workspaces.
# PRINTHUB_HOSTED=true
# Set these to the external HTTPS origin when running behind a reverse proxy.
# BETTER_AUTH_URL=https://printhub.example.com
# BETTER_AUTH_TRUSTED_ORIGINS=https://printhub.example.com
# Setting SMTP_HOST switches email delivery from Admin settings to the
# environment; EMAIL_FROM is then required and SMTP_PORT defaults to 587.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=printhub@example.com
# Override password sign-in; AUTH_PASSWORD_RECOVERY=true forces it on to
# recover a deployment locked out of its social login.
# AUTH_PASSWORD_ENABLED=true
# AUTH_PASSWORD_RECOVERY=false
# Social provider credentials must be configured in pairs. The optional
# enabled flags default to true and can disable a configured provider.
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_ENABLED=true
# AUTH_DISCORD_CLIENT_ID=
# AUTH_DISCORD_CLIENT_SECRET=
# AUTH_DISCORD_ENABLED=true
# Base64url-encoded 32-byte key used instead of /data/integration-secrets.key.
# INTEGRATIONS_ENCRYPTION_KEY=
# Pino log level (default info).
# LOG_LEVEL=info
