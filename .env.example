# Convex Cloud deployment URL (also baked into the client at build time)
VITE_CONVEX_URL=https://<deployment>.convex.cloud
# Public PostHog browser configuration, baked into locally built images
VITE_POSTHOG_PROJECT_TOKEN=phc_<project-token>
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Must match APP_WRITE_SECRET on the Convex deployment (npx convex env set APP_WRITE_SECRET <value>)
CONVEX_ACTION_SECRET=
# Comma-separated emails allowed to manage the board
ADMIN_EMAILS=you@example.com
# Host folder where STL files live (todo/, in-progress/, done/)
PRINTS_HOST_DIR=/mnt/HDDs/STL
