# Persistent metadata, sessions, and incomplete uploads
DATA_HOST_DIR=/mnt/HDDs/STL/.printhub-data
# Original STLs and generated previews. Default only: storage saved in
# Settings -> Storage takes precedence once configured.
PRINTS_HOST_DIR=/mnt/HDDs/STL

# local (default) or trusted-header
AUTH_PROVIDER=local
AUTH_EMAIL_HEADER=Cf-Access-Authenticated-User-Email
# Required in trusted-header mode; the proxy must overwrite this header.
TRUSTED_PROXY_SECRET=
# Used only when trusted-header creates a user for the first time
OPERATOR_EMAILS=you@example.com

# Optional telemetry; leave blank for no external telemetry
VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com
