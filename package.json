{
  "name": "printhub",
  "version": "0.16.0",
  "private": true,
  "description": "Self-hosted 3D print request queue: friends or customers upload STLs to a Kanban board, files stay as plain files on storage you control.",
  "homepage": "https://github.com/richardsolomou/printhub",
  "bugs": "https://github.com/richardsolomou/printhub/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/richardsolomou/printhub.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && esbuild src/server/assets/worker.ts --bundle --platform=node --format=esm --target=node22 --outfile=.output/server/assets-worker.mjs --log-level=warning",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware --deny-warnings .",
    "lint:fix": "oxlint --type-aware --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm check:cli",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "check:cli": "node --import tsx scripts/migrate-convex.ts --help && node --import tsx scripts/verify-convex-import.ts --help && node --import tsx scripts/backup.ts --help",
    "migrate:convex": "tsx scripts/migrate-convex.ts",
    "verify:convex": "tsx scripts/verify-convex-import.ts",
    "backup": "tsx scripts/backup.ts"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^3.0.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@posthog/react": "^1.10.3",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.1",
    "argon2": "^0.44.0",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "commander": "^15.0.0",
    "date-fns": "^4.4.0",
    "fast-png": "^8.0.0",
    "lucide-react": "^1.24.0",
    "maxrects-packer": "^2.7.3",
    "meshoptimizer": "^1.2.0",
    "nodemailer": "^9.0.3",
    "p-queue": "^9.3.1",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "posthog-js": "^1.399.2",
    "posthog-node": "^5.41.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-dropzone": "^16.0.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "tus-js-client": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "nitro": "3.0.260610-beta",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3"
    ]
  }
}
