{
  "name": "stlquest",
  "version": "1.1.0",
  "private": true,
  "description": "Private, self-hosted resin and filament request queue with fair ordering, printer assignment, and completion tracking.",
  "homepage": "https://stl.quest",
  "bugs": "https://github.com/richardsolomou/stl.quest/issues",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/richardsolomou/stl.quest.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && esbuild src/server/assets/worker.ts --bundle --platform=node --format=esm --target=node24 --outfile=.output/server/assets-worker.mjs --log-level=warning && rm -rf .output/server/drizzle && cp -R drizzle .output/server/drizzle",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware --deny-warnings .",
    "lint:fix": "oxlint --type-aware --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm format:check && pnpm lint && pnpm db:check && pnpm catalog:check && pnpm check:unraid && pnpm check:changesets && pnpm build && pnpm typecheck && pnpm test && pnpm check:cli",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:run": "playwright test",
    "test:e2e:screenshots": "pnpm build && CAPTURE_E2E_SCREENSHOTS=1 playwright test",
    "test:e2e:trace": "pnpm build && PLAYWRIGHT_TRACE=1 playwright test",
    "test:e2e:install": "playwright install chromium",
    "check:cli": "node --import tsx scripts/backup.ts --help",
    "check:changesets": "changeset status",
    "check:unraid": "tsx scripts/checkUnraidMetadata.ts",
    "catalog:check": "tsx scripts/syncPrinterCatalog.ts --check",
    "catalog:sync": "tsx scripts/syncPrinterCatalog.ts",
    "catalog:update": "tsx scripts/syncPrinterCatalog.ts --update && tsx scripts/updatePrinterImages.ts --update && tsx scripts/syncPrinterCatalog.ts",
    "catalog:update-images": "tsx scripts/updatePrinterImages.ts && tsx scripts/syncPrinterCatalog.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && tsx scripts/syncReleaseVersion.ts",
    "release": "changeset tag",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "backup": "tsx scripts/backup.ts"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^3.0.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/zilla-slab": "^5.2.8",
    "@headless-tree/core": "1.7.0",
    "@headless-tree/react": "1.7.0",
    "@posthog/react": "^1.10.3",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.1",
    "argon2": "^0.44.0",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "commander": "^15.0.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "fast-png": "^8.0.0",
    "lucide-react": "^1.24.0",
    "meshoptimizer": "^1.2.0",
    "nodemailer": "^9.0.3",
    "p-queue": "^9.3.1",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "posthog-js": "^1.399.2",
    "posthog-node": "^5.41.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-dropzone": "^17.0.0",
    "react-icons": "5.7.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "tus-js-client": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "webdav": "5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "nitro": "3.0.260610-beta",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.12.0"
}
